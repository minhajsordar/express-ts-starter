{
  "name": "express-ts",
  "version": "1.0.0",
  "description": "An Starter Project For ExpressTS Backend",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "watch": "tsc -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "npm test",
      "npm run build"
    ]
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ExpressTs",
    "ExpressJs"
  ],
  "author": "MinhajSordar",
  "license": "MIT",
  "dependencies": {
    "@types/express": "^5.0.3",
    "express": "^5.1.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.4",
    "lint-staged": "^16.1.2",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  }
}
